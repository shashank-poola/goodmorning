# Google OAuth — https://console.cloud.google.com/apis/credentials
# Enable: Google Calendar API + Gmail API
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/auth/google/callback

# Zhipu AI (GLM) — https://open.bigmodel.cn
# Powers: email insights, news summaries, tweet insights, LinkedIn reply drafts,
# yesterday recap, todo auto-priority + duplicate detection.
# Leave empty to run without the intelligence layer (data still shows, no insights).
ZAI_API_KEY=
ZAI_MODEL=glm-5.2

# Where to send the browser after OAuth succeeds
FRONTEND_URL=http://localhost:5173

# IANA timezone for "today's" calendar window (e.g. Asia/Kolkata, Europe/London)
CALENDAR_TIMEZONE=Europe/London

PORT=3001
